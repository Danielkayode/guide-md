{
  "name": "@prismteam/linter",
  "version": "0.2.3",
  "description": "The official linter for GUIDE.md — the AI Context Interface standard",
  "type": "module",
  "main": "./dist/cli/index.js",
  "bin": {
    "guidemd": "dist/cli/index.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:bundle",
    "build:bundle": "esbuild src/cli/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/cli/index.cjs --banner:js=\"#!/usr/bin/env node\" --external:esbuild && copy src\\doctor\\signatures.json dist\\cli\\signatures.json",
    "build:typecheck": "tsc --noEmit",
    "dev": "tsx src/cli/index.ts",
    "lint:self": "tsx src/cli/index.ts lint GUIDE.md",
    "lint:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "es-module-lexer": "^1.5.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "guidemd",
    "ai-context",
    "llm",
    "mcp",
    "linter",
    "documentation"
  ],
  "license": "MIT"
}
